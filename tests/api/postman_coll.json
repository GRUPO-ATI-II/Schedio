{
  "info": {
    "name": "Schedio API Tests - Auth",
    "_postman_id": "00000000-0000-0000-0000-000000000000",
    "description": "Pruebas funcionales de Registro y Login para el backend Schedio.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Registro de Usuario",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstName\": \"Test\",\n    \"lastName\": \"User\",\n    \"email\": \"newman{{$randomInt}}@test.com\",\n    \"password\": \"password123\",\n    \"birthDate\": \"2000-01-01\"\n}"
        },
        "url": {
          "raw": "http://backend:3000/api/users/register",
          "host": ["backend"],
          "port": "3000",
          "path": ["api", "users", "register"]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "pm.test(\"AC1: Registro exitoso - Status 201\", function () { pm.response.to.have.status(201); });",
            "pm.test(\"AC1: Retorna email correcto\", function () { pm.expect(pm.response.json().email).to.contain('@test.com'); });"
          ]
        }
      }]
    },
    {
      "name": "2. Login Exitoso",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"valerria02@gmail.com\",\n    \"password\": \"valcicco\"\n}"
        },
        "url": {
          "raw": "http://backend:3000/api/users/login",
          "host": ["backend"],
          "port": "3000",
          "path": ["api", "users", "login"]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "pm.test(\"AC2: Login exitoso - Status 200\", function () { pm.response.to.have.status(200); });",
            "pm.test(\"AC2: Verifica que retorne un JWT o ID\", function () { pm.expect(pm.response.json().user).to.have.property('id'); });"
          ]
        }
      }]
    },
    {
      "name": "3. Login Fallido - Credenciales Incorrectas",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"login@example.com\",\n    \"password\": \"wrongPassword\"\n}"
        },
        "url": {
          "raw": "http://backend:3000/api/users/login",
          "host": ["backend"],
          "port": "3000",
          "path": ["api", "users", "login"]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "pm.test(\"AC3: Manejo de error 401 para credenciales inválidas\", function () { pm.response.to.have.status(401); });"
          ]
        }
      }]
    },
    {
      "name": "4. Registro Fallido - Email Duplicado",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstName\": \"Duplicado\",\n    \"lastName\": \"User\",\n    \"email\": \"valerria02@gmail.com\",\n    \"password\": \"password123\",\n    \"birthDate\": \"2000-01-01\"\n}"
        },
        "url": {
          "raw": "http://backend:3000/api/users/register",
          "host": ["backend"],
          "port": "3000",
          "path": ["api", "users", "register"]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "pm.test(\"AC4: No permite registrar email duplicado (Status 400 o 409)\", function () { \n    pm.expect(pm.response.code).to.be.oneOf([400, 409]); \n});"
          ]
        }
      }]
    }
  ]
}